# Copy to .env for local dev
# Set these in Railway / Render environment variables for production

# Google Sheets (make the sheet "Anyone with link can view")
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_API_KEY=your_google_api_key_here

# Resend (free tier at resend.com — 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_AUDIENCE_ID=your_audience_id_here
FROM_EMAIL=drop@dispatch.press

# CORS — your Vercel frontend URL
FRONTEND_ORIGIN=https://your-project.vercel.app
